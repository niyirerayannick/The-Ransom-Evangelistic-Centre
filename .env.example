# Production (Coolify) — copy to Coolify environment variables
DEBUG=False
SECRET_KEY=change-me
ALLOWED_HOSTS=yvesgashugi.org,www.yvesgashugi.org
CSRF_TRUSTED_ORIGINS=https://yvesgashugi.org,https://www.yvesgashugi.org
SQLITE_DB_PATH=/app/data/db.sqlite3
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
MAINTENANCE_MODE=True

# Local development overrides (optional)
# DEBUG=True
# SECRET_KEY=local-dev-only
# ALLOWED_HOSTS=localhost,127.0.0.1
# SQLITE_DB_PATH=
# MEDIA_ROOT=
# STATIC_ROOT=
# MAINTENANCE_MODE=False

# Legacy names still supported locally:
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=
# DJANGO_ALLOWED_HOSTS=
# DJANGO_DB_PATH=
